# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.
# Block Python Virtual Environment & Cache
backend/ecommerce/
backend/venv/
backend/__pycache__/

# Block Secret Keys
backend/.env

# Block Databases (Too large/local only)
backend/ecommerce.db
backend/chroma_data/

# Block Node.js Heavy Folders
frontend/node_modules/
frontend/.next/
# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
